---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ShareButtons from "../components/ShareButtons.astro";
import ArticleNav from "../components/ArticleNav.astro";
import FormattedDate from "../components/FormattedDate.astro";
import TableOfContents from "../components/TableOfContents.astro";
import { getCollection, render } from "astro:content";
import { SITE_URL, sortPosts } from "../consts";

interface Props {
  id: string;
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date | null;
  tags?: string[];
  heroImage?: string;
}

const {
  id,
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  heroImage,
} = Astro.props;

const sortedTags = [...tags].sort((a, b) => a.localeCompare(b, "ja"));

// Get all posts for prev/next navigation — same canonical order as the list page
const allPosts = sortPosts(
  (await getCollection("blog")).filter((p) => !p.data.hidden),
);

const currentIndex = allPosts.findIndex((p) => p.id === id);
const prevPost =
  currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;

const articleUrl = `${SITE_URL}/blog/${id}`;

// Calculate reading time (Japanese: ~500 chars/min)
const slotContent = await Astro.slots.render("default");
const textLength = slotContent.replace(/<[^>]*>/g, "").length;
const readingTime = Math.max(1, Math.ceil(textLength / 500));

// Extract h1-h3 headings for table of contents
const headingRegex = /<h([1-3])([^>]*)>([\s\S]*?)<\/h[1-3]>/gi;
const headings: { level: number; id: string; text: string }[] = [];
let headingMatch: RegExpExecArray | null;
while ((headingMatch = headingRegex.exec(slotContent)) !== null) {
  const [, level, attrs, rawHtml] = headingMatch;
  const idMatch = attrs.match(/\bid="([^"]*)"/);
  if (!idMatch) continue;
  const text = rawHtml.replace(/<[^>]*>/g, "").trim();
  headings.push({ level: parseInt(level), id: idMatch[1], text });
}
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  article={true}
>
  <Header />
  <main class="container">
    <article id="article-top">
      <ArticleNav
        prevPost={prevPost
          ? { id: prevPost.id, title: prevPost.data.title }
          : null}
        nextPost={nextPost
          ? { id: nextPost.id, title: nextPost.data.title }
          : null}
      />

      <header class="article-header">
        <h1 class="article-title">{title}</h1>
        <p class="article-description">{description}</p>
        <div class="article-meta">
          <span class="meta-item">
            <iconify-icon
              icon="material-symbols:calendar-today-outline"
              width="14"
              height="14"
              aria-hidden="true"></iconify-icon>
            <FormattedDate date={pubDate} />
          </span>
          {
            updatedDate && (
              <span class="meta-item">
                <iconify-icon
                  icon="material-symbols:update"
                  width="14"
                  height="14"
                  aria-hidden="true"
                />
                <FormattedDate date={updatedDate} />
              </span>
            )
          }
          <span class="meta-item reading-time">
            <iconify-icon
              icon="material-symbols:schedule-outline"
              width="14"
              height="14"
              aria-hidden="true"></iconify-icon>
            約{readingTime}分
          </span>
        </div>
        {
          sortedTags.length > 0 && (
            <div class="article-tags">
              {sortedTags.map((tag) => (
                <a href={`/tag/${tag}`} class="tag">
                  #{tag}
                </a>
              ))}
            </div>
          )
        }
      </header>

      <div class="article-content">
        <slot />
      </div>

      <ShareButtons url={articleUrl} title={title} />

      <ArticleNav
        prevPost={prevPost
          ? { id: prevPost.id, title: prevPost.data.title }
          : null}
        nextPost={nextPost
          ? { id: nextPost.id, title: nextPost.data.title }
          : null}
      />
    </article>
  </main>
  <Footer />

  <!-- Fixed TOC (sidebar on desktop, overlay on mobile) -->
  <TableOfContents title={title} headings={headings} />

  <!-- Fixed page action buttons: TOC toggle (mobile) + scroll top/bottom -->
  <div class="page-actions">
    <button
      class="action-btn action-toc-btn"
      id="action-toc-btn"
      aria-label="目次"
      title="目次"
      aria-expanded="false"
    >
      <iconify-icon
        icon="material-symbols:format-list-bulleted"
        width="20"
        height="20"
      />
    </button>
    <button
      class="action-btn"
      id="action-top-btn"
      aria-label="ページトップへ"
      title="ページトップへ"
    >
      <iconify-icon
        icon="material-symbols:arrow-upward"
        width="20"
        height="20"
      />
    </button>
    <button
      class="action-btn"
      id="action-bottom-btn"
      aria-label="ページボトムへ"
      title="ページボトムへ"
    >
      <iconify-icon
        icon="material-symbols:arrow-downward"
        width="20"
        height="20"
      />
    </button>
  </div>

  <!-- Page action button scripts -->
  <script>
    const tocBtn = document.getElementById("action-toc-btn");
    tocBtn?.addEventListener("click", () => {
      const expanded = tocBtn.getAttribute("aria-expanded") === "true";
      if (expanded) {
        window.dispatchEvent(new Event("toc:close"));
        tocBtn.setAttribute("aria-expanded", "false");
      } else {
        window.dispatchEvent(new Event("toc:open"));
        tocBtn.setAttribute("aria-expanded", "true");
      }
    });

    document.getElementById("action-top-btn")?.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
    document
      .getElementById("action-bottom-btn")
      ?.addEventListener("click", () => {
        window.scrollTo({ top: document.body.scrollHeight, behavior: "smooth" });
      });
  </script>

  <!-- KaTeX fallback: render plain-text delimiters that were not converted at build time -->
  <script>
    async function initKatexFallback() {
      const articleRoot = document.querySelector(".article-content");
      if (!articleRoot) return;

      try {
        const { default: renderMathInElement } =
          // @ts-ignore
          await import("katex/dist/contrib/auto-render.mjs");
        renderMathInElement(articleRoot, {
          throwOnError: false,
          delimiters: [
            { left: "$$", right: "$$", display: true },
            { left: "\\[", right: "\\]", display: true },
            { left: "$", right: "$", display: false },
            { left: "\\(", right: "\\)", display: false },
          ],
        });
      } catch (err) {
        console.error("KaTeX fallback rendering error:", err);
      }
    }

    initKatexFallback();
  </script>

  <!-- Mermaid: initialise once the page is interactive -->
  <script>
    async function initMermaid() {
      const mermaidElements =
        document.querySelectorAll<HTMLElement>("pre.mermaid");
      if (mermaidElements.length === 0) return;

      const { default: mermaid } = await import("mermaid");
      const theme = document.documentElement.getAttribute("data-theme");
      mermaid.initialize({
        startOnLoad: false,
        theme: theme === "dark" ? "dark" : "default",
        securityLevel: "loose",
        fontFamily: "inherit",
      });

      try {
        await mermaid.run({ nodes: mermaidElements });
      } catch (err) {
        console.error("Mermaid rendering error:", err);
      }
    }

    // Re-run mermaid whenever the theme changes so diagrams match the palette
    function watchTheme() {
      const observer = new MutationObserver(() => {
        document
          .querySelectorAll("pre.mermaid[data-processed]")
          .forEach((el) => {
            el.removeAttribute("data-processed");
            // Restore original source stored in data-original
            const original = (el as HTMLElement).dataset.original;
            if (original) el.textContent = original;
          });
        initMermaid();
      });
      observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["data-theme"],
      });
    }

    // Store original diagram source before mermaid replaces the content
    document.querySelectorAll("pre.mermaid").forEach((el) => {
      (el as HTMLElement).dataset.original = el.textContent ?? "";
    });

    initMermaid().then(watchTheme);
  </script>

  <!-- Code copy buttons -->
  <script>
    function addCodeCopyButtons() {
      document.querySelectorAll("pre:not(.mermaid)").forEach((pre) => {
        if (pre.querySelector(".code-copy-btn")) return;
        const wrapper = document.createElement("div");
        wrapper.className = "code-block-wrapper";
        pre.parentNode?.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);

        const btn = document.createElement("button");
        btn.className = "code-copy-btn";
        btn.setAttribute("aria-label", "コードをコピー");
        btn.innerHTML =
          '<iconify-icon icon="material-symbols:content-copy-outline" width="14" height="14"></iconify-icon> Copy';
        btn.addEventListener("click", async () => {
          const code =
            pre.querySelector("code")?.textContent || pre.textContent || "";
          try {
            await navigator.clipboard.writeText(code);
          } catch {
            const ta = document.createElement("textarea");
            ta.value = code;
            ta.style.position = "fixed";
            ta.style.opacity = "0";
            document.body.appendChild(ta);
            ta.select();
            document.execCommand("copy");
            document.body.removeChild(ta);
          }
          btn.innerHTML =
            '<iconify-icon icon="material-symbols:check" width="14" height="14"></iconify-icon> Copied!';
          btn.classList.add("copied");
          setTimeout(() => {
            btn.innerHTML =
              '<iconify-icon icon="material-symbols:content-copy-outline" width="14" height="14"></iconify-icon> Copy';
            btn.classList.remove("copied");
          }, 2000);
        });
        wrapper.appendChild(btn);
      });
    }

    addCodeCopyButtons();
  </script>

  <!-- Twitter / X embed widget -->
  <script
    is:inline
    async
    src="https://platform.twitter.com/widgets.js"
    charset="utf-8"></script>
</BaseLayout>
