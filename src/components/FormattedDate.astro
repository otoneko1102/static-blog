---
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc.js";
import timezone from "dayjs/plugin/timezone.js";

dayjs.extend(utc);
dayjs.extend(timezone);

interface Props {
  date: Date;
}

const { date } = Astro.props;

const jst = dayjs(date).tz("Asia/Tokyo");
const formatted = jst.format("YYYY/MM/DD");
const datetimeTokyo = jst.format("YYYY-MM-DDTHH:mm:ssZ");
---

<time datetime={datetimeTokyo}>{formatted}</time>
