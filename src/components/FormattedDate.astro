---
interface Props {
  date: Date;
}

const { date } = Astro.props;

const formatted = date.toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
  timeZone: "Asia/Tokyo",
});

const datetimeTokyo = new Date(
  date.toLocaleString("en-CA", {
    timeZone: "Asia/Tokyo",
    hour12: false,
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
    hour: "2-digit",
    minute: "2-digit",
    second: "2-digit",
  }),
).toISOString();
---

<time datetime={datetimeTokyo}>{formatted}</time>
