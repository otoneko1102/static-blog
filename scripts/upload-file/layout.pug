doctype html
html(lang="ja")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title ファイル管理 — #{ articleId }
    link(rel="preconnect", href="https://fonts.googleapis.com")
    link(rel="preconnect", href="https://fonts.gstatic.com", crossorigin)
    link(
      rel="stylesheet",
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,400..600,0..1,-50..200"
    )
    link(rel="stylesheet", href="/cropper.css")
    link(rel="stylesheet", href="/uploader.css")
  body
    include partials/_header.pug
    .app-body
      include partials/_sidebar.pug
      include partials/_main.pug
    #toast.toast(role="status", aria-live="polite")
    script#uploader-config(type="application/json")!= configJson
    script(src="/cropper.js")
    script(src="/dayjs.js")
    script(src="/dayjs-utc.js")
    script(src="/dayjs-timezone.js")
    script.
      dayjs.extend(dayjs_plugin_utc);
      dayjs.extend(dayjs_plugin_timezone);
    script(src="/uploader.js")
