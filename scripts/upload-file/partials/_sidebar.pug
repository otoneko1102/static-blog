include _icon.pug

aside.sidebar(aria-label="ファイルツリー")
  .sidebar-section-title
    +icon("folder_open", "section-icon")
    span EXPLORER
  .sidebar-toolbar
    label.btn.file-label(title="ファイルをアップロード")
      +icon("upload")
      span.btn-label アップロード
      input#fileInput(
        type="file",
        accept="image/*,.heic,.heif,video/*,.mts,.m2ts,.ts,.flv,.wmv,.asf,.rm,.rmvb,audio/*,.wma,.aiff,.aif,.mid,.midi,.amr,.caf,application/pdf",
        multiple
      )
    button#mkdirBtn.btn.btn-icon-only(type="button", title="新規フォルダを作成")
      +icon("create_new_folder")
    button#refreshBtn.btn.btn-icon-only(type="button", title="再読み込み")
      +icon("refresh")
  .tree-root
    .tree-folder
      .tree-folder-row
        +icon("folder", "tree-folder-icon")
        span.tree-folder-name= articleId
      ul#fileList.tree-list
        li.tree-empty 読み込み中...

  hr.sidebar-divider

  button#otherArticlesToggle.sidebar-other-btn(type="button")
    +icon("folder_special", "section-icon")
    span.sidebar-other-label その他の記事
    span#otherCountBadge.other-count-badge(hidden)
    +icon("chevron_right", "other-chevron")

  #otherArticlesBody.other-articles-body(hidden)
